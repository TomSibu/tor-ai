# Backend environment variables for local development

# AI providers
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key
OPENAI_API_KEY=your_openai_api_key

# Piper text-to-speech
PIPER_BIN=piper
PIPER_MODEL_PATH=E:/models/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=E:/models/piper/en_US-lessac-medium.onnx.json
# Optional (for multi-speaker models)
PIPER_SPEAKER_ID=0
